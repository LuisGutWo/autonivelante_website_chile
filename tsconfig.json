{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    // ========================================
    // STRICT MODE: Enforce strong typing
    // ========================================
    "strict": true,
    // Los siguientes son habilitados automáticamente por "strict: true"
    // Se enumeran explícitamente para claridad:
    // - noImplicitAny
    // - strictNullChecks
    // - strictFunctionTypes
    // - strictBindCallApply
    // - strictPropertyInitialization
    // - noImplicitThis
    // - alwaysStrict
    // ========================================
    // PRAGMATISMO: Desactivar para código generado
    // ========================================
    "noUnusedLocals": false, // Next.js genera imports no utilizados en .next/types/
    "noUnusedParameters": false, // Mismo problema en tipos autogenerados
    // ========================================
    // BEST PRACTICES
    // ========================================
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true, // Redundante pero explícito
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/src/*": ["./src/*"],
      "@/redux/*": ["./redux/*"],
      "@/app/*": ["./app/*"],
      "@/public/*": ["./public/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
