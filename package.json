    "react-multi-carousel": "^2.8.5",
    "react-player": "^3.4.0",
    "react-redux": "^9.2.0",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.13.1",
    "react-suspense": "^0.1.0",
